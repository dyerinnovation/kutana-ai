{
  "name": "kutana-ai",
  "displayName": "Kutana AI Meeting Integration",
  "version": "0.2.0",
  "description": "Connect Claude Code to a Kutana AI meeting as a first-class participant. Raise your hand, chat, read the transcript, and receive live insights via the claude/channel protocol.",
  "author": "Kutana AI",
  "type": "mcp-server",
  "server": {
    "command": "bun",
    "args": ["./src/server.ts"],
    "env": {
      "KUTANA_API_URL": "ws://localhost:8003",
      "KUTANA_HTTP_URL": "http://localhost:8000",
      "KUTANA_MEETING_ID": "",
      "KUTANA_AGENT_MODE": "both",
      "KUTANA_ENTITY_FILTER": "",
      "KUTANA_AGENT_NAME": "Claude Code",
      "KUTANA_BEARER_TOKEN": ""
    }
  },
  "requiredEnv": ["KUTANA_API_KEY", "KUTANA_MEETING_ID"],
  "capabilities": ["claude/channel", "tools", "resources"],
  "tools": [
    "reply",
    "get_chat_messages",
    "accept_task",
    "update_status",
    "raise_hand",
    "get_queue_status",
    "mark_finished_speaking",
    "cancel_hand_raise",
    "get_speaking_status",
    "get_participants",
    "request_context",
    "get_meeting_recap",
    "get_entity_history"
  ],
  "resources": [
    "kutana://platform/context",
    "kutana://meeting/{meeting_id}/context"
  ],
  "readme": "See services/channel-server/README.md for setup and usage instructions.",
  "keywords": ["meeting", "transcript", "ai-agent", "kutana", "channel", "turn-management", "chat"]
}
