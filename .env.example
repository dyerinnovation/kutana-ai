# Infrastructure
DATABASE_URL=postgresql+asyncpg://convene:convene@localhost:5432/convene
REDIS_URL=redis://localhost:6379/0

# Deepgram STT
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-3

# Anthropic (for LLM extraction + demo agent)
ANTHROPIC_API_KEY=your-anthropic-key

# Agent Gateway
AGENT_GATEWAY_PORT=8003
AGENT_GATEWAY_JWT_SECRET=dev-secret-change-in-production
AGENT_GATEWAY_STT_PROVIDER=whisper-remote
AGENT_GATEWAY_WHISPER_API_URL=http://spark-b0f2.local/convene-stt/v1

# API Server
API_SERVER_PORT=8000

# Audio Service
AUDIO_SERVICE_PORT=8001
AUDIO_SERVICE_PUBLIC_URL=

# STT Provider Configuration
STT_PROVIDER=whisper-remote
WHISPER_API_URL=http://spark-b0f2.local/convene-stt/v1
WHISPER_MODEL_SIZE=small

# Security
JWT_SECRET=dev-secret-change-in-production

# LiveKit (WebRTC)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# TTS Providers (optional)
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Local LLM (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Groq (optional — free tier at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# AssemblyAI (optional STT provider)
ASSEMBLYAI_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=14
# Price IDs (populate by running: uv run python scripts/stripe_setup.py)
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
# Checkout redirect URLs
BILLING_SUCCESS_URL=http://localhost:5173/settings/billing?status=success
BILLING_CANCEL_URL=http://localhost:5173/pricing?status=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:5173/settings/billing
