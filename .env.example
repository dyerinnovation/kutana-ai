# Database
DATABASE_URL=postgresql+asyncpg://convene:convene@localhost:5432/convene

# Redis
REDIS_URL=redis://localhost:6379/0

# STT Providers
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# STT Provider Configuration
STT_PROVIDER=whisper-remote
WHISPER_API_URL=http://spark-b0f2.local/convene-stt/v1
WHISPER_MODEL_SIZE=small

# Audio Service Public URL
AUDIO_SERVICE_PUBLIC_URL=

# Agent Gateway
AGENT_GATEWAY_JWT_SECRET=change-me-in-production
AGENT_GATEWAY_PORT=8003
AGENT_GATEWAY_STT_PROVIDER=whisper-remote
AGENT_GATEWAY_WHISPER_API_URL=http://spark-b0f2.local/convene-stt/v1

# LiveKit (Phase P-B)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM Providers
ANTHROPIC_API_KEY=

# TTS Providers (Phase 2)
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Local Providers (no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Groq (free tier — get key at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
