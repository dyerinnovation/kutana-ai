# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Convene MCP server URL (default: http://localhost:3001)
MCP_SERVER_URL=http://localhost:3001

# MCP Bearer token (required)
# Get this by exchanging your API key:
#   curl -s http://localhost:8000/api/v1/token/mcp \
#     -H 'X-API-Key: cvn_...' | jq -r '.token'
MCP_BEARER_TOKEN=
