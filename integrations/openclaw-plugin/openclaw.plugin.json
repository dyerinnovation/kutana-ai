{
  "name": "@kutana/openclaw-plugin",
  "version": "0.1.0",
  "description": "Kutana AI meeting tools for OpenClaw agents",
  "main": "dist/index.js",
  "tools": [
    {
      "name": "kutana_list_meetings",
      "description": "List available Kutana AI meetings",
      "parameters": {}
    },
    {
      "name": "kutana_join_meeting",
      "description": "Join a Kutana AI meeting by ID",
      "parameters": {
        "meeting_id": {
          "type": "string",
          "description": "The meeting ID to join",
          "required": true
        }
      }
    },
    {
      "name": "kutana_get_transcript",
      "description": "Get recent transcript segments from the current meeting",
      "parameters": {
        "last_n": {
          "type": "number",
          "description": "Number of recent segments to return (default: 50)",
          "required": false
        }
      }
    },
    {
      "name": "kutana_create_task",
      "description": "Create a task/action item from a meeting",
      "parameters": {
        "meeting_id": {
          "type": "string",
          "description": "The meeting ID",
          "required": true
        },
        "description": {
          "type": "string",
          "description": "Task description",
          "required": true
        },
        "priority": {
          "type": "string",
          "description": "Priority: low, medium, high, critical",
          "required": false
        }
      }
    },
    {
      "name": "kutana_get_participants",
      "description": "List participants in the current meeting",
      "parameters": {}
    },
    {
      "name": "kutana_create_meeting",
      "description": "Create a new Kutana AI meeting",
      "parameters": {
        "title": {
          "type": "string",
          "description": "Meeting title",
          "required": true
        }
      }
    }
  ],
  "skills": ["skills/kutana"],
  "config": {
    "apiKey": {
      "type": "string",
      "description": "Kutana API key (cvn_...)",
      "required": true
    },
    "mcpUrl": {
      "type": "string",
      "description": "Kutana MCP server URL",
      "default": "https://kutana.spark-b0f2.local/mcp"
    }
  }
}
